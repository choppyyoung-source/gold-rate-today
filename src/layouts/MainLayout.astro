---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  schemas?: object[];
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const props = Astro.props;
const today = new Date().toISOString().split("T")[0];
---

<!doctype html>
<html lang="en-IN" dir="ltr">
  <head>
    <SEOHead {...props} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-6">
      <slot />
    </main>
    <Footer />

    <!-- Analytics & Ads (deferred, non-blocking) -->
    <script defer src="https://www.googletagmanager.com/gtag/js?id=G-LN4S018T01"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LN4S018T01');
    </script>
    <script defer src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5473625991326486" crossorigin="anonymous"></script>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "0175ea0990a542999ddc9284dbb44dab"}'></script>
  </body>
</html>
