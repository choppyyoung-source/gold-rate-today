---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  schemas?: object[];
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <SEOHead {...props} />
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5473625991326486" crossorigin="anonymous"></script>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-6">
      <slot />
    </main>
    <Footer />
    <!-- AdSense auto ads push -->
    <script>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "0175ea0990a542999ddc9284dbb44dab"}'></script>
  </body>
</html>
